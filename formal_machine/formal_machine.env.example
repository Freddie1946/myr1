# Copy to formal_machine.env and edit every path marked REQUIRED.

# Install destination on the formal Linux machine.
INSTALL_ROOT="$HOME/pathvlm_r1_v1_formal"

# Absolute path to this cloned Git repository or extracted transfer bundle. REQUIRED.
BUNDLE_ROOT="/absolute/path/to/cloned/myr1"

# Frozen split directory containing splits/, subsets/, manifest.json. REQUIRED.
SPLIT_ROOT="$BUNDLE_ROOT/data/pathmmu_image_disjoint_v1"

# Directory that will contain the required PathMMU image files.
IMAGE_ROOT="$INSTALL_ROOT/raw_data/pathmmu/images"

# PathMMU is gated. First obtain access at:
# https://huggingface.co/datasets/jamessyx/PathMMU
# Then run `hf auth login` on the formal machine or export HF_TOKEN.
# With ONLINE=1 and PATHMMU_AUTO_DOWNLOAD=1, setup downloads images.zip and
# extracts only the 3,809 images referenced by the frozen split.
PATHMMU_AUTO_DOWNLOAD=1
PATHMMU_DATASET_ID="jamessyx/PathMMU"
PATHMMU_DATASET_REVISION="main"
# Optional local images.zip, especially useful for offline setup.
PATHMMU_ARCHIVE=""

# Source trees, either bundled or copied separately. REQUIRED.
LLAMAFACTORY_SRC=""
VLMR1_SRC="$BUNDLE_ROOT/vendor/open-r1-multimodal"

# Conda executable. Use an absolute path when conda is not on PATH.
CONDA_EXE="conda"

# 1: download Python packages/model/data when needed; 0: strictly offline.
ONLINE=1

# Required when ONLINE=0. It must contain wheels for both environments.
WHEELHOUSE="$BUNDLE_ROOT/wheelhouse"

# Known-working debug versions. Override the PyTorch index for the formal driver if needed.
PYTORCH_INDEX_URL="https://download.pytorch.org/whl/cu118"
TORCH_VERSION="2.6.0"
TORCHVISION_VERSION="0.21.0"

# Exact formal base model.
BASE_MODEL_ID="Qwen/Qwen2.5-VL-7B-Instruct"
BASE_MODEL_REVISION="cc594898137f460bfe9f0759e9844b3ce807cfb5"

# For offline mode, point this at a complete local snapshot of the exact revision.
BASE_MODEL_SOURCE=""

# Set to 1 only when you intentionally want existing generated adapters overwritten.
OVERWRITE_DATA=0

# Formal distributed launcher. Edit for the actual machine.
CUDA_VISIBLE_DEVICES="0,1,2,3"
NPROC_PER_NODE=4
MASTER_PORT_BASE=29600

# Must satisfy: NPROC_PER_NODE * GRPO_PER_DEVICE_BATCH is divisible by 4.
GRPO_PER_DEVICE_BATCH=1
